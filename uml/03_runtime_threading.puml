@startuml runtime_threading
title vc::runtime - Task and Device Threading

skinparam backgroundColor #FAFAFA
skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam ArrowColor #2B4C7E
skinparam ClassBackgroundColor #EEF5FF

package "vc::model" {
  enum TaskState {
    Idle
    CommissionStarting
    Commission
    RuntimeStarting
    Ready
    RunningCycle
    Recovering
    Faulted
    Stopping
  }

  abstract class ITask <<QObject>> {
    +beginCommission()
    +endCommission()
    +beginRuntime(mergeToTaskThread=false)
    +endRuntime()
    +stopAll()
    +taskState() : TaskState
    +resyncDevices()
    #syncRunnersWithDevices()
  }

  class TaskLocalization <<QObject>> {
    +setupTask()
    +executeLocalization()
    +startCommissionMatching(group, image)
    -buildRuntimeContext() : RuntimeContext
    -queueSetActiveCameraNumber(number)
    -queueHandlePlcValues(values)
  }

  class LocalizationRuntimeController <<QObject>> {
    +configure(config)
    +setActiveCameraNumber(cameraNumber)
    +setActivePatternGroupNumber(patternGroupNumber)
    +setup(context) : SetupResult
    +execute()
    +handlePlcValues(values)
    +onRuntimeMatchingFinished(cycleId, result)
    --
    +runtimeMatchingRequested(cycleId, group, image)
    +cycleResultUpdated(result)
    +taskLogAppended(entry)
    +runtimeCycleStarted(message)
    +runtimeRecovering(message)
    +runtimeReady(message)
    +runtimeFault(message)
  }

  class RuntimeContext {
    +config : TaskLocalizeConfig
    +primaryPlcRunner : PlcRunner*
    +visionOutputRunner : VisionOutputRunner*
    +cameraRunners : QMap<int, CameraRunner*>
    +patternGroups : QMap<int, MatchGroup>
    +cameraCalibrators : QMap<int, Calibrator>
  }

  enum LocalizationRecoveryAction {
    Ignore
    RetryScheduled
    EscalateFault
  }

  class LocalizationRecoveryPolicy {
    +roleName : QString
    +maxRetries : int
    +retryIntervalMs : int
    +connectTimeoutMs : int
    +retryOnConnectFailed : bool
    +retryOnLostConnected : bool
    +isRecoverableStatus(status) : bool
    +canRetry(currentRetryCount) : bool
  }

  class LocalizationSignalMapper {
    +configure(config)
    +mapValues(values) : QList<LocalizationSignalEvent>
  }

  class LocalizationPipeline {
    +runMatch(group, image) : MatchResult
  }
}

package "vc::runtime" {
  enum Phase {
    Idle
    Commission
    Runtime
  }

  enum DeviceCommandKind {
    Unknown
    Connect
    Disconnect
    CameraSingleShot
    CameraApplyParams
  }

  enum DeviceCommandResultStatus {
    Accepted
    Rejected
    Succeeded
    Failed
  }

  enum DeviceCommandResultCode {
    None
    Busy
    UnsupportedCommand
    InvalidTarget
    DeviceError
    TimedOut
    QueueFull
  }

  enum DeviceCommandQueuePolicy {
    RejectWhenBusy
    QueueWhenBusy
    ReplacePendingSameKind
  }

  class DeviceCommand {
    +id : QString
    +kind : DeviceCommandKind
    +targetDeviceId : QString
    +timeoutMs : int
    +payload : QVariantMap
    +create(kind, targetDeviceId, timeoutMs, payload)
  }

  class DeviceCommandResult {
    +commandId : QString
    +kind : DeviceCommandKind
    +targetDeviceId : QString
    +status : DeviceCommandResultStatus
    +code : DeviceCommandResultCode
    +message : QString
    +payload : QVariantMap
  }

  class DeviceCommandQueue {
    +enqueue(command, policy, busy) : DeviceCommandEnqueueDecision
    +hasPending() : bool
    +takeNext() : DeviceCommand
    +pendingCount() : int
  }

  abstract class IDeviceRunner <<QObject>> {
    +start()
    +stop()
    +attach()
    +detach(dest)
    +workerThread() : QThread*
    +device() : IDevice*
    +isAttached() : bool
    +isRunning() : bool
    +submitCommand(command) : DeviceCommandResult
  }

  abstract class "DeviceRunner<TDevice>" as DeviceRunner {
    +start()
    +stop()
    +attach()
    +detach(dest)
    +typedDevice() : TDevice*
    #wireSignals()
    #unwireSignals()
  }

  class TaskRunner <<QObject>> {
    +registerDevice(deviceId, device)
    +unregisterDevice(deviceId)
    +runnerFor(deviceId) : IDeviceRunner*
    +hasRunner(deviceId) : bool
    +enterCommission()
    +enterRuntime(mergeToTaskThread=false)
    +enterIdle()
    -createRunner(device) : IDeviceRunner*
  }

  class CameraRunner <<QObject>> {
    +submitCommand(command) : DeviceCommandResult
    +requestConnect()
    +requestDisconnect()
    +requestSingleShot()
    +requestApplyParams()
  }

  class PlcRunner <<QObject>> {
    +requestConnect()
    +requestDisconnect()
    +requestWriteDigitalIo(tag, value)
    +requestWriteWordIo(tag, value)
  }

  class VisionOutputRunner <<QObject>> {
    +requestConnect()
    +requestDisconnect()
    +requestSendResult(positions)
    --
    +resultRequestFinished(ok, message)
  }
}

package "vc::device" {
  abstract class IDevice <<QObject>> {
    +deviceDetachThread(dest)
    +deviceThreadDetached()
  }

  abstract class CameraDevice <<QObject>>
  abstract class PlcDevice <<QObject>>
  abstract class VisionOutputDevice <<QObject>>
  abstract class RobotDevice <<QObject>>
  interface IPlcIoWriter {
    +writeDigitalIoByName(tag, value) : bool
    +writeWordIoByName(tag, value) : bool
  }
}

ITask <|-- TaskLocalization
ITask *-- TaskRunner : m_taskRunner
ITask --> TaskState : current task lifecycle
TaskLocalization *-- LocalizationRuntimeController : runtime orchestration
TaskLocalization *-- LocalizationPipeline : matching pipeline
LocalizationRuntimeController *-- LocalizationSignalMapper : PLC tag mapping
LocalizationRuntimeController *-- LocalizationRecoveryPolicy : per-role policies
LocalizationRuntimeController *-- RuntimeContext : immutable runtime snapshot
LocalizationRuntimeController ..> LocalizationRecoveryAction : retry decision
LocalizationRuntimeController ..> PlcRunner : connect valueChanged
LocalizationRuntimeController ..> PlcRunner : queued PLC output writes
LocalizationRuntimeController ..> CameraRunner : queued single-shot request
LocalizationRuntimeController ..> VisionOutputRunner : queued result request
LocalizationRuntimeController ..> LocalizationPipeline : via matching worker signal
TaskLocalization ..> LocalizationRuntimeController : queued task-to-controller calls
TaskLocalization ..> LocalizationPipeline : matching worker owns runMatch()
TaskRunner *-- "0..*" IDeviceRunner : m_runners[deviceId]
TaskRunner *-- "1" QThread : m_runtimeThread
TaskRunner --> Phase : currentPhase
IDeviceRunner ..> DeviceCommand : standard command input
IDeviceRunner ..> DeviceCommandResult : commandFinished(result)
DeviceCommand --> DeviceCommandKind
DeviceCommandResult --> DeviceCommandKind
DeviceCommandResult --> DeviceCommandResultStatus
DeviceCommandResult --> DeviceCommandResultCode
DeviceCommandQueue --> DeviceCommandQueuePolicy
CameraRunner *-- DeviceCommandQueue : m_commandQueue
CameraRunner *-- QTimer : m_activeCommandTimer

IDeviceRunner <|-- DeviceRunner
DeviceRunner <|-- CameraRunner
DeviceRunner <|-- PlcRunner
DeviceRunner <|-- VisionOutputRunner

DeviceRunner *-- QThread : per-device worker
DeviceRunner o-- IDevice : raw pointer, not owned
CameraRunner --> CameraDevice
CameraRunner ..> DeviceCommand : routes request* methods
CameraRunner ..> DeviceCommandResult : busy/invalid/final result
PlcRunner --> PlcDevice
PlcRunner ..> IPlcIoWriter : optional write capability
VisionOutputRunner --> VisionOutputDevice

TaskRunner ..> CameraRunner : Camera devices
TaskRunner ..> PlcRunner : PLC devices
TaskRunner ..> VisionOutputRunner : VisionOutput devices
TaskRunner ..> RobotDevice : unsupported by createRunner()

note right of TaskRunner
  createRunner() currently supports:
  Camera, PLC, VisionOutput.

  Robot devices are ignored because
  RobotRunner does not exist yet.
end note

note right of CameraRunner
  A31 extends CameraRunner with command queue and timeout handling.
  Queue policy:
  Connect/Disconnect -> reject while active.
  CameraSingleShot -> FIFO queue.
  CameraApplyParams -> replace pending same-kind request.
  Active command timeout emits Failed(TimedOut).
end note

note right of LocalizationRuntimeController
  Phase 2 separates runtime-only setup from TaskLocalization:
  role validation, PLC runner signal wiring, PLC tag mapping,
  and future trigger/image/output orchestration live here.

  A32 adds role-based recovery policy handling for:
  camera / primary_plc / vision_output.
  LostConnected or ConnectFailed -> retry each 5s up to 10 times,
  then raise runtime fault with role + retry history.

  A50 surfaces runtimeRecovering/runtimeReady/runtimeFault so
  TaskLocalization can keep an explicit task-level state machine.

  Localization runtime now publishes cycle result and task-local log
  events for the dashboard, plus runtimeCycleStarted for the async
  RunningCycle transition.

  Current implementation keeps per-device threads and uses queued
  runner APIs. The controller object is moved into TaskRunner::m_runtimeThread
  during runtime and is not parented to TaskLocalization while moved.

  TaskLocalization builds RuntimeContext before setup, then invokes setup(),
  execute(), PLC-value handling, and active camera/pattern changes through
  queued controller calls.

  Runtime matching is async: the controller emits runtimeMatchingRequested(),
  the TaskLocalization matching worker runs LocalizationPipeline::runMatch(),
  and the result returns through onRuntimeMatchingFinished(cycleId, result).

  Lifecycle state machines are documented separately in
  08_runtime_state_machines.puml to keep this class/threading diagram
  valid as a single PlantUML diagram type.
end note

@enduml
