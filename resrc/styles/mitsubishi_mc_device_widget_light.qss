/* ═════════════════════════════════════════════════════════════════
   Mitsubishi MC Device Widget - Light theme — Hybrid (Graphite Vision + Orange)
   bg.window: #f2f3f5  bg.surface: #ffffff  border.default: #c8ccd4
   accent.primary: #c06400  state.success: #1a7a40  state.error: #c0282a
   Dynamic property "connectionState" ("connected"/"disconnected") drives
   dot, label, and button colour variants via attribute selectors.
   ═════════════════════════════════════════════════════════════════ */

QWidget#MitsubishiMcDeviceWidget {
    background-color: @{bg.window};
}

/* ── Labels ──────────────────────────────────────────────────── */

QLabel#lbl_conn_title {
    color: @{text.muted};
    font: 700 9pt "Segoe UI";
    letter-spacing: 1px;
}

QLabel#lbl_meta_frame {
    color: @{text.muted};
    font: 9pt "JetBrains Mono";
    letter-spacing: 1px;
}

QLabel#lbl_meta_hint {
    color: @{text.disabled};
    font: italic 9pt "Segoe UI";
}

QLabel#lbl_ip,
QLabel#lbl_port,
QLabel#lbl_conn_timeout,
QLabel#lbl_resp_timeout {
    color: @{text.muted};
    font: 700 8pt "Segoe UI";
    letter-spacing: 1px;
}

/* ── Input fields ────────────────────────────────────────────── */

QLineEdit#ledit_ip,
QSpinBox#spb_port,
QSpinBox#spb_conn_timeout,
QSpinBox#spb_resp_timeout {
    background-color: @{bg.surface};
    color: @{text.primary};
    border: 1px solid @{border.default};
    border-radius: 5px;
    padding: 6px 10px;
    font: 11pt "JetBrains Mono";
    min-height: 22px;
}
QLineEdit#ledit_ip:focus,
QSpinBox#spb_port:focus,
QSpinBox#spb_conn_timeout:focus,
QSpinBox#spb_resp_timeout:focus {
    border-color: @{accent.primary};
}

/* ── Splitter ────────────────────────────────────────────────── */

QSplitter#splitter_device_table::handle       { background-color: @{bg.window}; }
QSplitter#splitter_device_table::handle:hover { background-color: @{accent.primary}; }
