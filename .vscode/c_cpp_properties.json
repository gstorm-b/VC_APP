{
  "configurations": [
    {
      "name": "windows-gcc-x64",
      "includePath": [
        "${workspaceFolder}/**"
      ],
      "defines": [
        "_WINDOWS",
        "_WIN64",
        "UNICODE",
        "_UNICODE",
        "QT_CORE_LIB",
        "QT_GUI_LIB",
        "QT_WIDGETS_LIB",
        "QT_NETWORK_LIB",
        "QT_SQL_LIB"
      ],
      "compilerPath": "C:/MSYS64/MINGW64/BIN/gcc.exe",
      "cStandard": "${default}",
      "cppStandard": "${default}",
      "intelliSenseMode": "windows-gcc-x64"
    }
  ],
  "version": 4
}