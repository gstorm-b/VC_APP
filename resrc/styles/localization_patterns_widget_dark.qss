/* ═══════════════════════════════════════════════════════════════════════
   LocalizationPatternsWidget — Dark theme  (Hybrid: Graphite Vision + Orange)
   bg.window: #1a1c20   bg.surface: #22252a   bg.elevated: #2c3038
   border.default: #3a3f48   accent.primary: #e87c00
   Dynamic properties:
     QLabel  [role]        = kpi-label | kpi-value | sep
     QLabel  [role="sep"]  vertical separator between KPI groups
   ═══════════════════════════════════════════════════════════════════════ */

/* ── Root ─────────────────────────────────────────────────────────────── */
QWidget#LocalizationPatternsWidget {
    background: @{bg.window};
    color: @{text.primary};
}

/* ── Toolbar bar ──────────────────────────────────────────────────────── */
QFrame#frame_toolbar {
    background: @{bg.surface};
    border-bottom: 1px solid @{border.default};
}

QToolButton#btn_trigger_camera,
QToolButton#btn_choose_image,
QToolButton#btn_set_workspace,
QToolButton#btn_run_match {
    background: transparent;
    border: 1px solid @{border.default};
    border-radius: 4px;
    padding: 4px 10px;
    color: @{text.primary};
    font: 9pt 'Segoe UI';
}
QToolButton#btn_trigger_camera:hover,
QToolButton#btn_choose_image:hover,
QToolButton#btn_set_workspace:hover,
QToolButton#btn_run_match:hover {
    background: @{bg.elevated};
    border-color: @{border.strong};
}
QToolButton#btn_trigger_camera:pressed,
QToolButton#btn_choose_image:pressed,
QToolButton#btn_set_workspace:pressed,
QToolButton#btn_run_match:pressed {
    background: @{accent.subtle};
    border-color: @{accent.primary};
}
QToolButton#btn_run_match {
    background: @{accent.subtle};
    border-color: @{accent.primary};
    color: @{accent.bright};
    font-weight: 700;
}
QToolButton#btn_run_match:hover   { background: rgba(232,124,0,0.20); }
QToolButton#btn_run_match:pressed { background: rgba(176,90,0,0.25); }

/* ── State pill ───────────────────────────────────────────────────────── */
QLabel#label_state_pill {
    background: @{bg.elevated};
    color: @{text.muted};
    border: 1px solid @{border.default};
    border-radius: 4px;
    font: 700 8pt 'Segoe UI';
    letter-spacing: 1px;
    padding: 2px 10px;
}

/* ── Operate bar ──────────────────────────────────────────────────────── */
QFrame#frame_operate {
    background: @{bg.window};
    border-bottom: 1px solid @{bg.elevated};
}

/* ── View header (monitor pane) ───────────────────────────────────────── */
QFrame#frame_view_header {
    background: @{bg.surface};
    border-bottom: 1px solid @{border.default};
}

QPushButton#btn_view_raw,
QPushButton#btn_view_result {
    background: transparent;
    border: 1px solid @{border.default};
    border-radius: 3px;
    padding: 3px 10px;
    color: @{text.muted};
    font: 9pt 'Segoe UI';
}
QPushButton#btn_view_raw:hover,
QPushButton#btn_view_result:hover   { background: @{bg.elevated}; color: @{text.primary}; }
QPushButton#btn_view_raw:checked,
QPushButton#btn_view_result:checked {
    background: @{accent.subtle};
    border-color: @{accent.primary};
    color: @{accent.bright};
}

/* ── Section header labels ────────────────────────────────────────────── */
QLabel#label_monitor_title,
QLabel#label_library_title,
QLabel#label_inspector_title,
QLabel#label_property_title {
    background: @{bg.surface};
    color: @{text.muted};
    border-bottom: 1px solid @{border.default};
    font: 700 7.5pt 'Segoe UI';
    letter-spacing: 1.2px;
    padding: 0px 4px;
}

/* ── KPI bar ──────────────────────────────────────────────────────────── */
QFrame#frame_kpi {
    background: @{bg.surface};
    border-top: 1px solid @{border.default};
}

QLabel[role="kpi-label"] {
    color: @{text.muted};
    font: 700 7pt 'Segoe UI';
    letter-spacing: 1.2px;
    background: transparent;
}
QLabel[role="kpi-value"] {
    color: @{text.primary};
    font: 700 14pt 'JetBrains Mono';
    background: transparent;
}
QLabel[role="sep"] {
    background: @{border.default};
    min-width: 1px;
    max-width: 1px;
    margin: 6px 0px;
}

/* ── Status bar ───────────────────────────────────────────────────────── */
QFrame#frame_status {
    background: @{bg.surface};
    border-top: 1px solid @{border.default};
}
QLabel#label_status_text,
QLabel#label_status_image,
QLabel#label_status_groups {
    color: @{text.muted};
    font: 8pt 'Segoe UI';
    background: transparent;
}
