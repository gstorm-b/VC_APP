/* ═════════════════════════════════════════════════════════════════
   Mitsubishi MC Device Widget - Dark theme — Hybrid (Graphite Vision + Orange)
   bg.window: #1a1c20  bg.surface: #22252a  border.default: #3a3f48
   accent.primary: #e87c00  state.success: #40c870  state.error: #ff5252
   Dynamic property "connectionState" ("connected"/"disconnected") drives
   dot, label, and button colour variants via attribute selectors.
   ═════════════════════════════════════════════════════════════════ */

QWidget#MitsubishiMcDeviceWidget {
    background-color: @{bg.window};
}

/* ── Labels ──────────────────────────────────────────────────── */

QLabel#lbl_conn_title {
    color: @{text.muted};
    font: 700 9pt "Segoe UI";
    letter-spacing: 1px;
}

QLabel#lbl_meta_frame {
    color: @{text.muted};
    font: 9pt "JetBrains Mono";
    letter-spacing: 1px;
}

QLabel#lbl_meta_hint {
    color: @{text.disabled};
    font: italic 9pt "Segoe UI";
}

QLabel#lbl_ip,
QLabel#lbl_port,
QLabel#lbl_conn_timeout,
QLabel#lbl_resp_timeout {
    color: @{text.muted};
    font: 700 8pt "Segoe UI";
    letter-spacing: 1px;
}

/* ── Input fields ────────────────────────────────────────────── */

QLineEdit#ledit_ip,
QSpinBox#spb_port,
QSpinBox#spb_conn_timeout,
QSpinBox#spb_resp_timeout {
    background-color: @{bg.window};
    color: @{text.primary};
    border: 1px solid @{border.strong};
    border-radius: 5px;
    padding: 6px 10px;
    font: 11pt "JetBrains Mono";
    min-height: 22px;
}
QLineEdit#ledit_ip:focus,
QSpinBox#spb_port:focus,
QSpinBox#spb_conn_timeout:focus,
QSpinBox#spb_resp_timeout:focus {
    border-color: @{accent.primary};
}
