/* ═════════════════════════════════════════════════════════════════
   Vision TCP/IP Client Device Widget - Light theme — Hybrid (Graphite Vision + Orange)
   bg.window: #f2f3f5  bg.surface: #ffffff  border.default: #c8ccd4
   accent.primary: #c06400  state.success: #1a7a40  state.error: #c0282a
   Dynamic property "connectionState" ("connected"/"disconnected") drives
   dot, label, and button colour variants via attribute selectors.
   ═════════════════════════════════════════════════════════════════ */

QWidget#VisionTcpipClientDeviceWidget {
    background-color: @{bg.window};
}

/* ── Connection card ─────────────────────────────────────────── */

QFrame#frame_connection {
    background-color: @{bg.surface};
    border: 1px solid @{border.default};
    border-radius: 8px;
}

/* ── Labels ──────────────────────────────────────────────────── */

QLabel#lbl_conn_title {
    color: @{text.muted};
    font: 700 9pt "Segoe UI";
    letter-spacing: 1px;
}

QLabel#lbl_ip,
QLabel#lbl_port_heartbeat,
QLabel#lbl_port_data {
    color: @{text.muted};
    font: 700 8pt "Segoe UI";
    letter-spacing: 1px;
}

/* ── Input fields ────────────────────────────────────────────── */

QLineEdit#ledit_ip,
QSpinBox#spb_port_heartbeat,
QSpinBox#spb_port_data {
    background-color: @{bg.surface};
    color: @{text.primary};
    border: 1px solid @{border.default};
    border-radius: 5px;
    padding: 6px 10px;
    font: 11pt "JetBrains Mono";
    min-height: 22px;
}
QLineEdit#ledit_ip:focus,
QSpinBox#spb_port_heartbeat:focus,
QSpinBox#spb_port_data:focus {
    border-color: @{accent.primary};
}

/* ── Connection status dot ───────────────────────────────────── */

QLabel#lbl_conn_dot {
    border-radius: 5px;
    min-width: 10px; max-width: 10px;
    min-height: 10px; max-height: 10px;
}
QLabel#lbl_conn_dot[connectionState="connected"]    { background-color: @{state.success}; }
QLabel#lbl_conn_dot[connectionState="connecting"]   { background-color: @{accent.bright}; }
QLabel#lbl_conn_dot[connectionState="disconnected"] { background-color: @{state.error}; }

/* ── Connection status text ──────────────────────────────────── */

QLabel#lbl_conn_state {
    font: 700 9pt "Segoe UI";
    letter-spacing: 1px;
}
QLabel#lbl_conn_state[connectionState="connected"]    { color: @{state.success}; }
QLabel#lbl_conn_state[connectionState="connecting"]   { color: @{accent.bright}; }
QLabel#lbl_conn_state[connectionState="disconnected"] { color: @{state.error}; }

/* ── Connect / Disconnect button ─────────────────────────────── */

QPushButton#btn_connect {
    border-radius: 5px;
    padding: 7px 22px;
    font: 700 10pt "Segoe UI";
}
QPushButton#btn_connect[connectionState="disconnected"] {
    background-color: @{accent.primary};
    color: @{bg.surface};
    border: none;
}
QPushButton#btn_connect[connectionState="disconnected"]:hover   { background-color: @{accent.bright}; }
QPushButton#btn_connect[connectionState="disconnected"]:pressed { background-color: @{accent.pressed}; }
QPushButton#btn_connect[connectionState="connected"] {
    background-color: rgba(192, 40, 42, 0.10);
    color: @{state.error};
    border: 1px solid rgba(192, 40, 42, 0.30);
}
QPushButton#btn_connect[connectionState="connected"]:hover   { border-color: @{state.error}; }
QPushButton#btn_connect[connectionState="connected"]:pressed { background-color: rgba(192, 40, 42, 0.18); }
QPushButton#btn_connect[connectionState="connecting"] {
    background-color: rgba(176, 112, 0, 0.10);
    color: @{accent.bright};
    border: 1px solid @{accent.bright};
}
QPushButton#btn_connect[connectionState="connecting"]:hover   { border-color: @{accent.bright}; }
QPushButton#btn_connect[connectionState="connecting"]:pressed { background-color: rgba(176, 112, 0, 0.18); }

/* ── Send result card ────────────────────────────────────────── */

QFrame#frame_send_result {
    background-color: @{bg.surface};
    border: 1px solid @{border.default};
    border-radius: 8px;
}

QLabel#lbl_send_title {
    color: @{text.muted};
    font: 700 9pt "Segoe UI";
    letter-spacing: 1px;
}

QLabel#lbl_send_hint {
    font: 9pt "Segoe UI";
}
QLabel#lbl_send_hint[sendState="ready"] { color: @{state.success}; }
QLabel#lbl_send_hint[sendState="idle"]  { color: @{text.muted}; }

/* ── Send section buttons (+ Row / - Row) ────────────────────── */

QPushButton#btn_add_row,
QPushButton#btn_remove_row {
    background-color: transparent;
    color: @{text.muted};
    border: 1px solid @{border.default};
    border-radius: 4px;
    padding: 3px 10px;
    font: 9pt "Segoe UI";
}
QPushButton#btn_add_row:hover,
QPushButton#btn_remove_row:hover {
    background-color: @{bg.window};
    color: @{text.primary};
}
QPushButton#btn_add_row:pressed,
QPushButton#btn_remove_row:pressed { background-color: @{border.default}; }

/* ── Send Result primary button ──────────────────────────────── */

QPushButton#btn_send_result {
    background-color: @{accent.primary};
    color: @{bg.surface};
    border: none;
    border-radius: 5px;
    padding: 7px 22px;
    font: 700 10pt "Segoe UI";
}
QPushButton#btn_send_result:hover   { background-color: @{accent.bright}; }
QPushButton#btn_send_result:pressed { background-color: @{accent.pressed}; }
QPushButton#btn_send_result:disabled {
    background-color: @{border.default};
    color: @{text.muted};
}

/* ── Position table ──────────────────────────────────────────── */

QTableWidget#tbl_positions {
    background-color: @{bg.surface};
    color: @{text.primary};
    border: 1px solid @{border.default};
    border-radius: 4px;
    gridline-color: @{border.default};
    selection-background-color: @{accent.subtle};
}
QTableWidget#tbl_positions QHeaderView::section {
    background-color: @{bg.window};
    color: @{text.muted};
    font: 700 8pt "Segoe UI";
    letter-spacing: 1px;
    border: none;
    border-bottom: 1px solid @{border.default};
    padding: 4px;
}
QTableWidget#tbl_positions QDoubleSpinBox {
    background-color: transparent;
    color: @{text.primary};
    border: none;
    font: 10pt "JetBrains Mono";
    padding: 2px 4px;
}
QTableWidget#tbl_positions QDoubleSpinBox:focus { background-color: @{accent.subtle}; }
