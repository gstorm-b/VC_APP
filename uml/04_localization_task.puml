@startuml localization_task
title vc::model - Localization Task

skinparam backgroundColor #FAFAFA
skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam ArrowColor #2B4C7E
skinparam ClassBackgroundColor #EEF5FF

package "vc::model" {
  enum TaskType {
    UndefineTask
    LocalizationTask
    PickPlaceTask
    InspectTask
  }

  enum CameraSourceType {
    Source_Owned
    Source_Shared
  }

  enum TaskState {
    Idle
    CommissionStarting
    Commission
    RuntimeStarting
    Ready
    RunningCycle
    Recovering
    Faulted
    Stopping
  }

  abstract class ITaskConfig {
    +taskType() : TaskType
    +toJson() : QJsonObject
    +fromJson(obj) : bool
    +copy() : ITaskConfig*
  }

  abstract class ITask <<QObject>> {
    +taskType() : TaskType
    +isValid() : bool
    +taskState() : TaskState
    +assignDevice(deviceId)
    +unassignDevice(deviceId)
    +assignedDevicesOfType(type)
    +setTaskConfig(cfg)
    +taskConfig() : ITaskConfig*
    +getTaskImageMap() : QMap<QString, cv::Mat>
    +loadTaskImageMap(mapping) : bool
    +toJson() : QJsonObject
    +fromJson(obj) : bool
  }

  class TaskLocalizeConfig <<Q_GADGET>> {
    +nActiveCamera : QString
    +nActivePatternGroup : QString
    +nDetectedNumber : QString
    +nFaultCode : QString
    +bCameraValid : QString
    +bPatternValid : QString
    +bTaskReady : QString
    +bTaskFault : QString
    +bExecuteTrigger : QString
    +bMatchingFinished : QString
    +bMatchingBusy : QString
    +bMatchingDetected : QString
    +bMatchingLowArea : QString
    +deviceBindings : TaskDeviceBindings
  }

  enum TaskDeviceRole {
    Unknown
    PrimaryPlc
    VisionOutput
    CameraNumber
  }

  class TaskDeviceBinding {
    +role() : TaskDeviceRole
    +deviceId() : QString
    +cameraNumber() : int
    +toJson() : QJsonObject
    +fromJson(obj) : bool
  }

  class TaskDeviceBindings {
    +primaryPlcDeviceId() : QString
    +setPrimaryPlcDeviceId(deviceId)
    +visionOutputDeviceId() : QString
    +setVisionOutputDeviceId(deviceId)
    +cameraNumberMap() : QMap<int, QString>
    +setCameraNumberMap(mapping)
    +cameraDeviceId(cameraNumber) : QString
    +toJson() : QJsonArray
    +fromJson(value) : bool
  }

  class TaskLocalization <<QObject>> {
    +taskType() : LocalizationTask
    +isReachLimitOfDeviceType(type) : bool
    +beginRuntime(mergeToTaskThread=false)
    +endRuntime()
    +stopAll()
    +setTaskLocalizeConfig(cfg)
    +taskLocalizeConfig() : TaskLocalizeConfig
    +patternManager() : PatternGroupManager*
    +getTaskImageMap() : QMap<QString, cv::Mat>
    +loadTaskImageMap(mapping) : bool
    +setupTask()
    +executeLocalization()
    +setCameraNumber(number)
    +setPatternNumber(number)
    -buildRuntimeContext() : RuntimeContext
    -setupRuntimeController() : SetupResult
    -queueHandlePlcValues(values)
    -queueSetActiveCameraNumber(number)
  }

  class LocalizationRuntimeController <<QObject>> {
    +configure(config)
    +setActiveCameraNumber(cameraNumber)
    +setActivePatternGroupNumber(patternGroupNumber)
    +setup(context) : SetupResult
    +execute()
    +handlePlcValues(values)
    +onRuntimeMatchingFinished(cycleId, result)
    --
    +runtimeMatchingRequested(cycleId, group, image)
    +cycleResultUpdated(result)
    +taskLogAppended(entry)
    +runtimeCycleStarted(message)
    +runtimeRecovering(message)
    +runtimeReady(message)
    +runtimeFault(message)
  }

  class RuntimeContext {
    +config : TaskLocalizeConfig
    +primaryPlcDeviceId : QString
    +visionOutputDeviceId : QString
    +primaryPlcRunner : PlcRunner*
    +visionOutputRunner : VisionOutputRunner*
    +cameraDeviceIds : QMap<int, QString>
    +cameraRunners : QMap<int, CameraRunner*>
    +patternGroups : QMap<int, MatchGroup>
    +cameraCalibrators : QMap<int, Calibrator>
    +activeCameraNumber : int
    +activePatternGroupNumber : int
  }

  class CycleResult {
    +faulted : bool
    +faultCode : LocalizationFaultCode
    +detectedNumber : int
    +sentNumber : int
    +matchingTimeMs : double
    +lowArea : bool
  }

  class ResultRow {
    +index : int
    +patternName : QString
    +score : double
    +imageX : double
    +imageY : double
    +imageR : double
    +world : VisionOutputPosition
    +status : QString
  }

  class TaskLogEntry {
    +timestamp : QDateTime
    +severity : QString
    +message : QString
  }

  enum LocalizationRecoveryAction {
    Ignore
    RetryScheduled
    EscalateFault
  }

  enum LocalizationFaultCode {
    None = 0
    CameraLost = 100
    CameraConnectFailed = 101
    CameraGrabTimeout = 102
    VisionOutputLost = 200
    VisionOutputSendFailed = 201
    PlcLost = 300
    PatternInvalid = 400
    CalibrationInvalid = 401
    InternalError = 500
  }

  class LocalizationRecoveryPolicy {
    +roleName : QString
    +maxRetries : int
    +retryIntervalMs : int
    +connectTimeoutMs : int
    +retryOnConnectFailed : bool
    +retryOnLostConnected : bool
  }

  class LocalizationSignalMapper {
    +configure(config)
    +signalNameForTag(tag) : QString
    +tagForSignalName(name) : QString
    +mapValues(values) : QList<LocalizationSignalEvent>
  }

  class LocalizationSignalEvent {
    +sourceTag : QString
    +name : QString
    +value : QVariant
  }

  class LocalizationPipeline {
    +runMatch(group, image) : MatchResult
  }

  class CameraMapEntry <<Q_GADGET>>
}

package "vc::device" {
  abstract class IDevice
  abstract class CameraDevice
  abstract class PlcDevice
  abstract class VisionOutputDevice
  class VisionOutputPosition
  class VisionOutputRequest
}

package "vc::runtime" {
  class TaskRunner
  class CameraRunner
  class PlcRunner
  class VisionOutputRunner
}

package "mtc" {
  class PatternGroupManager <<QObject>>
  class MatchGroup
  class MatchPattern
  class ImageMatcher
  struct MatchResult
}

ITaskConfig <|-- TaskLocalizeConfig
ITask <|-- TaskLocalization

ITask *-- TaskRunner
ITask --> IDevice : assignedDeviceIds resolve via Project/DeviceManager
ITask --> CameraSourceType
ITask --> TaskType
ITask --> TaskState

TaskLocalization *-- TaskLocalizeConfig : m_config
TaskLocalizeConfig *-- TaskDeviceBindings : deviceBindings
TaskDeviceBindings o-- "0..*" TaskDeviceBinding
TaskDeviceBinding --> TaskDeviceRole
TaskLocalization *-- PatternGroupManager : m_patternManager
TaskLocalization *-- LocalizationRuntimeController : explicit owner, no QObject parent in runtime
TaskLocalization *-- LocalizationPipeline : m_pipeline
LocalizationRuntimeController *-- LocalizationSignalMapper : m_signalMapper
LocalizationRuntimeController *-- LocalizationRecoveryPolicy : camera/plc/output policies
LocalizationRuntimeController *-- RuntimeContext : runtime snapshot
LocalizationRuntimeController ..> LocalizationRecoveryAction : policy decision
LocalizationRuntimeController --> LocalizationFaultCode : publishes stable codes
LocalizationRuntimeController ..> CycleResult : emits dashboard result
CycleResult o-- "0..*" ResultRow
CycleResult --> LocalizationFaultCode
ResultRow --> VisionOutputPosition
TaskLocalization ..> TaskLogEntry : emits task log
LocalizationSignalMapper ..> LocalizationSignalEvent : creates
LocalizationPipeline ..> ImageMatcher : local matcher
TaskLocalization --> MatchResult : m_lastMatchResult
TaskLocalization --> PlcDevice : plcDevice()
TaskLocalization ..> CameraRunner : typed runner access
TaskLocalization ..> PlcRunner : typed runner access
TaskLocalization ..> VisionOutputRunner : via task runner
TaskLocalization ..> LocalizationRuntimeController : queued task-to-controller calls
TaskLocalization ..> LocalizationPipeline : matching worker thread
LocalizationRuntimeController ..> VisionOutputRequest : send match result
LocalizationRuntimeController ..> VisionOutputPosition : world-coordinate payload
LocalizationRuntimeController ..> PlcRunner : connects valueChanged
LocalizationRuntimeController ..> PlcRunner : queued output writes
LocalizationRuntimeController ..> CameraRunner : single-shot requests
LocalizationRuntimeController ..> VisionOutputRunner : result request
LocalizationRuntimeController ..> RuntimeContext : validates registered runners

PatternGroupManager o-- "0..*" MatchGroup
MatchGroup o-- "0..*" MatchPattern
LocalizationPipeline ..> MatchGroup
LocalizationPipeline ..> MatchPattern
ImageMatcher ..> MatchGroup
ImageMatcher ..> MatchPattern

TaskDeviceBindings --> CameraDevice : camera_number role
TaskDeviceBindings --> PlcDevice : primary_plc role
TaskDeviceBindings --> VisionOutputDevice : vision_output role

note right of TaskLocalization
  TaskLocalization now keeps persistent config,
  pattern ownership, and lifecycle entry points.
  Runtime setup, PLC signal translation, cycle
  orchestration, fault outputs, and dashboard
  result/log signals are
  delegated to LocalizationRuntimeController.
  During runtime, controller calls are queued and the
  controller lives on TaskRunner::runtimeThread().
  A50 adds explicit taskState transitions around
  commission, runtime start, cycle execution,
  recovery, fault, and stopping.
end note

note right of LocalizationRuntimeController
  Runtime reconnect/fault behavior is delegated to
  explicit recovery policies per device role.
  Recovery/fault signals now feed the task state machine.
  The controller does not call TaskLocalization directly.
  It receives an immutable RuntimeContext snapshot at setup,
  coordinates device runners through queued APIs, and emits
  runtimeMatchingRequested() so matching runs on the task
  matching worker thread.
end note

note right of LocalizationSignalMapper
  Signal map direction:
  PLC tag -> logical task signal name.
  Runtime output publishing also uses reverse lookup:
  logical task signal name -> PLC tag.

  Unmapped tags are logged and skipped by a
  range-style pass, so one unmapped tag cannot
  block the PLC value thread.
end note

note bottom of TaskLocalization
  Binary pattern images are not embedded directly in JSON.
  getTaskImageMap() exposes keys like g{groupNumber}_p{patternNumber};
  ProjectRepository stores those cv::Mat images in project_images.
end note

@enduml
