@startuml state_phase
title TaskRunner Phase — State Machine

skinparam backgroundColor #fafafa
skinparam stateBackgroundColor #daeaf8
skinparam stateBorderColor #4a6080
skinparam stateArrowColor #0078d4
skinparam stateFontSize 12
skinparam noteBackgroundColor #fffde7
skinparam noteBorderColor #c8b400
skinparam ArrowFontSize 10

[*] --> Idle : TaskRunner created

' ═══════════════════════════════════
state Idle {
    Idle : entry / all threads stopped
    Idle : Devices live on GUI thread
    Idle : Runners created but not started
}

' ═══════════════════════════════════
state Commission {
    Commission : entry / each device → own QThread (HighPriority)
    Commission : attach() wires QueuedConnection signals
    Commission : Widget ↔ Runner ↔ Device (cross-thread safe)
    --
    [*] --> WiringSignals
    WiringSignals --> Ready : all runners attached
    state WiringSignals {
        WiringSignals : runner.start() per device
        WiringSignals : runner.attach() per device
        WiringSignals : device.moveToThread(workerThread)
        WiringSignals : wireSignals() per runner
    }
    state Ready {
        Ready : Widget can call requestConnect()
        Ready : Widget can call requestSingleShot()
        Ready : connectStatusChanged arrives on GUI thread
    }
}

' ═══════════════════════════════════
state Runtime {
    Runtime : Per-device threads continue running
    Runtime : m_runtimeThread (coordinator) starts
    Runtime : executeLocalization() on RT thread
    --
    state "Per-Device Mode\n(default)" as PerDevice {
        PerDevice : Each device stays on its own thread
        PerDevice : RT thread coordinates via signals
        PerDevice : Camera grab + PLC polling are parallel
    }
    state "Merged Mode\n(optional)" as Merged {
        Merged : All devices moved to m_runtimeThread
        Merged : Per-device threads stopped
        Merged : Sequential IO — simpler but slower
    }
    [*] --> PerDevice
    PerDevice --> Merged : enterRuntime(merge=true)
}

' ═══════════════════════════════════
' Transitions
Idle       --> Commission : enterCommission()\n[registerDevice for each\nassigned device ID]
Commission --> Idle       : enterIdle()\n[detach + stop all runners]
Commission --> Runtime    : enterRuntime()\n[RT thread starts alongside\nexisting device threads]
Runtime    --> Idle       : enterIdle()\n[detach + stop all,\nRT thread quits]
Idle       --> Runtime    : enterRuntime()\n[runners start fresh\nif not running]

' ═══════════════════════════════════
' Notes
note right of Idle
  Initial state.
  Created once per Task lifetime.
  Device objects live on main thread.
end note

note right of Commission
  One QThread per device.
  Widget drives device via runner signals.
  No direct Widget→Device calls.
end note

note right of Runtime
  Recommended: keep per-device threads.
  RT thread = task coordinator.
  Camera grab and PLC polling are truly
  parallel and non-blocking.
end note

note bottom of Runtime
  Thread map (Per-Device mode):
  ┌─────────────────────────────────────────┐
  │  GUI Thread   → Widget UI updates       │
  │  Thread A     → CameraDevice (grab)     │
  │  Thread B     → McProtocolDevice (poll) │
  │  RT Thread    → executeLocalization()   │
  └─────────────────────────────────────────┘
end note

@enduml
