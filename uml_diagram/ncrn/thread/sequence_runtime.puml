@startuml sequence_runtime
title Runtime Phase — Sequence Diagram\n(per-device threads mode — recommended)

skinparam backgroundColor #fafafa
skinparam sequenceArrowColor #4a6080
skinparam sequenceLifeLineBorderColor #4a6080
skinparam sequenceLifeLineBackgroundColor #f0f4f8
skinparam sequenceParticipantBorderColor #4a6080
skinparam sequenceParticipantBackgroundColor #daeaf8
skinparam sequenceBoxBackgroundColor #f5f8fc
skinparam noteBackgroundColor #fffde7
skinparam noteBorderColor #c8b400
skinparam sequenceDividerBackgroundColor #eef2f7
skinparam sequenceGroupBorderColor #007a00
skinparam sequenceGroupBackgroundColor #f0fff0

actor User
participant "LocalizationTaskWidget\n[GUI Thread]" as Widget #daeaf8
participant "TaskLocalization\n[GUI Thread]" as Task #daeaf8
participant "TaskRunner\n[GUI Thread]" as Runner #eef8ea
participant "CameraRunner" as CamRunner #eef8ea
participant "McDeviceRunner" as McRunner #eef8ea

box "Thread RT  (NormalPriority)\nTask Coordinator" #fff5f0
    participant "executeLocalization()\nlogic" as RTLogic
end box

box "Thread A  (HighPriority)\nCamera" #fff8f0
    participant "CameraDevice" as Cam
end box

box "Thread B  (HighPriority)\nPLC" #f0fff8
    participant "McProtocolDevice" as Plc
end box

== Transition: Commission → Runtime ==

User -> Widget : clicks [Start Runtime]
Widget -> Task  : beginRuntime()

group beginRuntime(mergeToTaskThread=false)
    Task -> Task    : syncRunnersWithDevices()
    note right: runners already exist\nfrom commission phase;\nonly registers any new devices

    Task -> Runner  : enterRuntime(false)

    Runner -> CamRunner : isRunning() → already running ✓
    Runner -> McRunner  : isRunning() → already running ✓
    note right: per-device threads keep\nrunning — no restart needed

    Runner -> Runner : m_runtimeThread->start(NormalPriority)
    note right: Task coordinator thread\nstarts separately
end

Task -> Widget  : runtimeStarted()
Widget -> Widget : updateUI(runtime mode)

== Runtime execution loop ==

note over RTLogic : executeLocalization()\nruns on RT thread\nper task trigger

RTLogic -> CamRunner : requestSingleShot()\n[QueuedConnection]

CamRunner ->> Cam : sig_singleShot()\n«QueuedConnection»
note over Cam : grab on Thread A\n(non-blocking for RT thread)

Cam -> CamRunner : grabFinished(result)\n«QueuedConnection»
CamRunner -> RTLogic : grabFinished(result)\n«QueuedConnection»

RTLogic -> RTLogic : m_matcher.match(result.frame)
note right: image processing\non RT thread

RTLogic -> McRunner : (future) pushRequest(writeResult)

McRunner ->> Plc : request via internal queue
note over Plc : PLC write on Thread B
Plc -> McRunner : requestFinished(result)

== PLC polling (autonomous — always running) ==

loop  every polling interval
    Plc -> Plc : onPollingTimerTimeout()
    Plc -> McRunner : pollingUpdate(deviceMap)\n«QueuedConnection»
    McRunner -> RTLogic : pollingUpdate(deviceMap)
    RTLogic -> RTLogic : react to PLC state changes
end

== Stop runtime ==

User -> Widget : clicks [Stop]
Widget -> Task  : endRuntime()

group endRuntime() → enterIdle()
    Runner -> CamRunner : detach(nullptr)
    CamRunner -> Cam    : moveToThread(mainThread)
    CamRunner -> CamRunner : unwireSignals()
    Runner -> CamRunner : stop()
    note right: Thread A quits

    Runner -> McRunner  : detach(nullptr)
    McRunner -> Plc     : moveToThread(mainThread)
    McRunner -> McRunner : unwireSignals()
    Runner -> McRunner  : stop()
    note right: Thread B quits

    Runner -> Runner : m_runtimeThread->quit()
    note right: RT coordinator thread quits
end

Task -> Widget  : runtimeStopped()

@enduml
