/* ═══════════════════════════════════════════════════════════════════
   Dark theme — Hybrid (Graphite Vision + Orange)
   bg.window:      #1a1c20    bg.surface:    #22252a    bg.elevated: #2c3038
   accent.primary: #e87c00    selection.bg:  #3d2e10    text:        #e0e4ea
   ═══════════════════════════════════════════════════════════════════ */

QToolTip {
    color: @{text.primary};
    background-color: @{bg.surface};
    border: 1px solid @{border.default};
}

/* ── Menu ────────────────────────────────────────────────────────── */

QMenuBar {
    background-color: @{bg.surface};
    color: @{text.primary};
}
QMenuBar::item:selected { background-color: @{selection.bg}; }

QMenu {
    background-color: @{bg.surface};
    color: @{text.primary};
    border: 1px solid @{border.default};
}
QMenu::item:selected  { background-color: @{selection.bg}; color: @{text.primary}; }
QMenu::separator      { height: 1px; background: @{border.default}; margin: 2px 0; }

/* ── Status / Toolbar ────────────────────────────────────────────── */

QStatusBar { background-color: @{accent.primary}; color: @{text.on-accent}; }

QToolBar {
    background-color: @{bg.surface};
    border: 1px solid @{border.default};
    spacing: 2px;
}
QToolButton {
    color: @{text.primary};
    background-color: transparent;
    border: none;
    padding: 4px;
    border-radius: 3px;
}
QToolButton:hover   { background-color: @{bg.elevated}; }
QToolButton:pressed { background-color: @{accent.pressed}; color: @{text.on-accent}; }
QToolButton:checked { background-color: @{selection.bg}; color: @{accent.primary}; }

/* ── Tree / Header ───────────────────────────────────────────────── */

QTreeView {
    background-color: @{bg.surface};
    color: @{text.primary};
    border: none;
}
QTreeView::item:hover    { background-color: @{bg.elevated}; }
QTreeView::item:selected { background-color: @{selection.bg}; color: @{text.primary}; }

QHeaderView::section {
    background-color: @{bg.surface};
    color: @{text.primary};
    border: 1px solid @{border.default};
    padding: 2px 4px;
}

/* ── Scrollbar ───────────────────────────────────────────────────── */

QScrollBar:vertical {
    background: @{bg.surface};
    width: 10px;
    margin: 0;
}
QScrollBar::handle:vertical {
    background: @{border.strong};
    border-radius: 4px;
    min-height: 20px;
}
QScrollBar::handle:vertical:hover { background: @{text.muted}; }
QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical { height: 0; }

QScrollBar:horizontal {
    background: @{bg.surface};
    height: 10px;
    margin: 0;
}
QScrollBar::handle:horizontal {
    background: @{border.strong};
    border-radius: 4px;
    min-width: 20px;
}
QScrollBar::handle:horizontal:hover { background: @{text.muted}; }
QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal { width: 0; }

/* ── GroupBox ────────────────────────────────────────────────────── */

QGroupBox {
    color: @{text.primary};
    border: 1px solid @{border.default};
    border-radius: 4px;
    margin-top: 8px;
    padding-top: 4px;
}
QGroupBox::title {
    color: @{text.primary};
    subcontrol-origin: margin;
    left: 8px;
    padding: 0 4px;
}

/* ── Input fields ────────────────────────────────────────────────── */

QLineEdit {
    background-color: @{bg.elevated};
    color: @{text.primary};
    border: 1px solid @{border.default};
    border-radius: 3px;
    padding: 2px 4px;
}
QLineEdit:focus    { border-color: @{accent.primary}; }
QLineEdit:disabled { background-color: @{bg.disabled}; color: @{text.disabled}; border-color: @{border.disabled}; }

QTextEdit,
QPlainTextEdit {
    background-color: @{bg.window};
    color: @{text.primary};
    border: 1px solid @{border.default};
    border-radius: 3px;
    padding: 2px 4px;
}
QTextEdit:focus,
QPlainTextEdit:focus    { border-color: @{accent.primary}; }
QTextEdit:read-only,
QPlainTextEdit:read-only { background-color: @{bg.window}; color: @{text.primary}; border-color: @{border.disabled}; }
QTextEdit:disabled,
QPlainTextEdit:disabled  { background-color: @{bg.disabled}; color: @{text.disabled}; border-color: @{border.disabled}; }

QComboBox {
    background-color: @{bg.elevated};
    color: @{text.primary};
    border: 1px solid @{border.default};
    border-radius: 3px;
    padding: 2px 4px;
}
QComboBox:focus { border-color: @{accent.primary}; }
QComboBox::drop-down { border-left: 1px solid @{border.default}; }
CompactComboBox::drop-down { border: none; }
QComboBox QAbstractItemView {
    background-color: @{bg.surface};
    color: @{text.primary};
    border: 1px solid @{border.default};
    selection-background-color: @{selection.bg};
    selection-color: @{text.primary};
}

QSpinBox,
QDoubleSpinBox {
    background-color: @{bg.elevated};
    color: @{text.primary};
    border: 1px solid @{border.default};
    border-radius: 3px;
}
QSpinBox:focus,
QDoubleSpinBox:focus { border-color: @{accent.primary}; }

/* ── Buttons ─────────────────────────────────────────────────────── */

QPushButton {
    background-color: @{bg.elevated};
    color: @{text.primary};
    border: 1px solid @{border.default};
    border-radius: 3px;
    padding: 4px 12px;
}
QPushButton:hover    { background-color: @{border.default}; border-color: @{accent.primary}; }
QPushButton:pressed  { background-color: @{accent.pressed}; color: @{text.on-accent}; }
QPushButton:default  { border-color: @{accent.primary}; border-width: 2px; }
QPushButton:disabled { color: @{text.disabled}; background-color: @{bg.disabled}; border-color: @{border.disabled}; }

ConnectionActionButton {
    border-radius: 5px;
    padding: 7px 22px;
    font: 700 10pt "Segoe UI";
}
ConnectionActionButton[connectionState="disconnected"] {
    background-color: @{accent.primary};
    color: @{text.on-accent};
    border: none;
}
ConnectionActionButton[connectionState="disconnected"]:hover {
    background-color: @{accent.bright};
}
ConnectionActionButton[connectionState="disconnected"]:pressed {
    background-color: @{accent.pressed};
}
ConnectionActionButton[connectionState="connected"] {
    background-color: rgba(255, 82, 82, 0.12);
    color: @{state.error};
    border: 1px solid rgba(255, 82, 82, 0.27);
}
ConnectionActionButton[connectionState="connected"]:hover {
    border-color: @{state.error};
}
ConnectionActionButton[connectionState="connected"]:pressed {
    background-color: rgba(255, 82, 82, 0.22);
}
ConnectionActionButton[connectionState="connecting"] {
    background-color: @{accent.subtle};
    color: @{accent.bright};
    border: 1px solid @{accent.bright};
}
ConnectionActionButton[connectionState="connecting"]:hover {
    border-color: @{accent.bright};
}
ConnectionActionButton[connectionState="connecting"]:pressed {
    background-color: rgba(232,124,0,0.18);
}

/* ── Labels / Checkboxes ─────────────────────────────────────────── */

QCheckBox { color: @{text.primary}; }
QLabel    { color: @{text.primary}; }

FrameBox {
    background-color: @{bg.surface};
    border: 1px solid @{border.default};
    border-radius: 8px;
}
FrameBox[frameBoxVariant="compact"] { border-radius: 4px; }
FrameBox QLabel { background: transparent; }

ConnectionStateDot {
    border-radius: 5px;
    min-width: 10px;
    max-width: 10px;
    min-height: 10px;
    max-height: 10px;
}
ConnectionStateDot[connectionState="connected"]    { background-color: @{state.success}; }
ConnectionStateDot[connectionState="connecting"]   { background-color: @{accent.bright}; }
ConnectionStateDot[connectionState="disconnected"] { background-color: @{state.error}; }

ConnectionStateLabel {
    font: 700 9pt "Segoe UI";
    letter-spacing: 1px;
}
ConnectionStateLabel[connectionState="connected"]    { color: @{state.success}; }
ConnectionStateLabel[connectionState="connecting"]   { color: @{accent.bright}; }
ConnectionStateLabel[connectionState="disconnected"] { color: @{state.error}; }

SendStateHintLabel {
    font: 9pt "Segoe UI";
}
SendStateHintLabel[sendState="ready"] { color: @{state.success}; }
SendStateHintLabel[sendState="idle"]  { color: @{text.disabled}; }

StatusLampDot { border-radius: 5px; }
StatusLampDot[lampState="on"] {
    background: qradialgradient(cx:0.35, cy:0.35, radius:0.65,
        stop:0 @{state.success.bright}, stop:1 @{state.success});
    border: 1px solid rgba(64,200,112,100);
}
StatusLampDot[lampState="off"] {
    background: qradialgradient(cx:0.35, cy:0.35, radius:0.65,
        stop:0 @{state.error.bright}, stop:1 @{state.error});
    border: 1px solid rgba(255,82,82,100);
}
StatusLampDot[lampState="warn"] {
    background: qradialgradient(cx:0.35, cy:0.35, radius:0.65,
        stop:0 @{state.warning.bright}, stop:1 @{state.warning});
    border: 1px solid rgba(255,176,32,100);
}
StatusLampDot[lampState="error"] {
    background: qradialgradient(cx:0.35, cy:0.35, radius:0.65,
        stop:0 @{state.error.bright}, stop:1 @{state.error});
    border: 1px solid rgba(255,82,82,100);
}

StatusTextLabel {
    font: 700 6.5pt "Segoe UI";
    letter-spacing: 0.5px;
}
StatusTextLabel[lampState="on"]    { color: @{text.muted}; }
StatusTextLabel[lampState="off"]   { color: @{text.disabled}; }
StatusTextLabel[lampState="warn"]  { color: @{state.warning}; }
StatusTextLabel[lampState="error"] { color: @{state.error}; }

TypeChipLabel {
    color: @{text.primary};
    border-radius: 4px;
    padding: 2px 8px;
    font-size: 8pt;
    font-weight: 600;
}
TypeChipLabel[typeKind="bool"] {
    background-color: rgba(64, 168, 224, 0.18);
    color: @{state.info};
}
TypeChipLabel[typeKind="number"] {
    background-color: rgba(64, 200, 112, 0.18);
    color: @{state.success};
}

StatePillLabel {
    border-radius: 4px;
    padding: 2px 10px;
    font-size: 9pt;
    font-weight: 700;
    min-width: 36px;
}
StatePillLabel[onOffState="on"] {
    background-color: rgba(64, 200, 112, 0.18);
    color: @{state.success};
}
StatePillLabel[onOffState="off"] {
    background-color: @{bg.elevated};
    color: @{text.muted};
}

/* ── Tabs ────────────────────────────────────────────────────────── */

QTabWidget::pane { border: 1px solid @{border.default}; }
QTabBar::tab {
    background-color: @{bg.surface};
    color: @{text.primary};
    border: 1px solid @{border.default};
    padding: 4px 12px;
}
QTabBar::tab:selected { background-color: @{bg.window}; border-bottom-color: transparent; }
QTabBar::tab:hover    { background-color: @{bg.elevated}; }

/* ── Table ───────────────────────────────────────────────────────── */

QTableWidget,
QTableView {
    background-color: @{bg.surface};
    color: @{text.primary};
    gridline-color: @{border.default};
}
QTableWidget::item:selected,
QTableView::item:selected { background-color: @{selection.bg}; color: @{text.primary}; }

FlatListWidget::item {
    border: none;
    padding: 0px;
    margin: 0px;
    background: transparent;
}
FlatListWidget::item:selected { background: transparent; }
FlatListWidget::item:hover { background: transparent; }

DeviceNavItemWidget[navItem="true"] {
    border: 1px solid transparent;
    background: transparent;
    border-radius: 5px;
}
DeviceNavItemWidget[navItem="true"]:hover {
    background: @{bg.elevated};
}
DeviceNavItemWidget[navItem="true"][navActive="true"][deviceType="camera"] {
    background: @{device.camera.tint.bg};
    border: 1px solid @{device.camera.tint.bd};
}
DeviceNavItemWidget[navItem="true"][navActive="true"][deviceType="plc"] {
    background: @{device.plc.tint.bg};
    border: 1px solid @{device.plc.tint.bd};
}
DeviceNavItemWidget[navItem="true"][navActive="true"][deviceType="output"] {
    background: @{device.output.tint.bg};
    border: 1px solid @{device.output.tint.bd};
}
DeviceNavItemWidget[navItem="true"][navActive="true"][deviceType="robot"] {
    background: @{device.robot.tint.bg};
    border: 1px solid @{device.robot.tint.bd};
}
DeviceNavItemWidget[navItem="true"][navActive="true"][deviceType="default"] {
    background: @{device.default.tint.bg};
    border: 1px solid @{device.default.tint.bd};
}
DeviceNavItemWidget[navItem="true"][navActive="true"] QLabel[navPart="name"] {
    color: @{text.primary};
    font-weight: bold;
}

DeviceNavDot {
    border-radius: 2px;
}
DeviceNavDot[lampState="on"] {
    background: @{state.success};
    border: 1px solid @{bg.window};
}
DeviceNavDot[lampState="warn"] {
    background: @{state.warning};
    border: 1px solid @{bg.window};
}
DeviceNavDot[lampState="off"] {
    background: @{state.error};
    border: 1px solid @{bg.window};
}

/* ── Slider ──────────────────────────────────────────────────────── */

QSlider::groove:horizontal {
    background: @{bg.elevated};
    height: 4px;
    border-radius: 2px;
}
QSlider::handle:horizontal {
    background: @{accent.primary};
    width: 12px;
    height: 12px;
    border-radius: 6px;
    margin: -4px 0;
}

/* ── Misc ────────────────────────────────────────────────────────── */
QSplitter::handle { background-color: @{bg.window}; }
QSplitter::handle:hover { background-color: @{accent.primary}; }

QMainWindow { background-color: @{bg.window}; }
QDialog     { background-color: @{bg.surface}; }
QWizard     { background-color: @{bg.surface}; }
QWizardPage { background-color: @{bg.surface}; }

QAbstractScrollArea { background-color: @{bg.surface}; }

/* ═══════════════════════════════════════════════════════════════════
   PatternTreeWidget — Dark theme
   bg.window: #1a1c20    bg.surface: #22252a    bg.elevated: #2c3038
   accent.primary: #e87c00    selection.bg: #3d2e10
   state.error: #ff5252    text.muted: #8899aa
   ═══════════════════════════════════════════════════════════════════ */

PatternTreeWidget {
    background-color: @{bg.window};
    border: none;
    outline: none;
}
PatternTreeWidget::item {
    padding: 0;
    margin: 0;
    border: none;
    background: transparent;
}
PatternTreeWidget::item:selected        { background-color: @{selection.bg}; }
PatternTreeWidget::item:hover:!selected { background-color: @{bg.elevated}; }
PatternTreeWidget::branch               { background-color: @{bg.window}; }

PatternTreeWidget QFrame[patternRole="groupAccent"] {
    background-color: @{accent.primary};
    border-radius: 2px;
}

PatternTreeWidget QLabel[patternRole="groupName"] {
    color: @{text.primary};
    font-size: 13px;
    font-weight: 700;
}

PatternTreeWidget QLabel[patternRole="groupNumber"] {
    color: @{accent.primary};
    background-color: @{accent.subtle};
    border: 1px solid rgba(232, 124, 0, 0.30);
    border-radius: 3px;
    padding: 1px 5px;
    font-size: 11px;
}

PatternTreeWidget QLabel[patternRole="thumbnail"] {
    background-color: @{bg.window};
    border: 1px solid @{border.default};
    border-radius: 5px;
    color: @{text.muted};
    font-size: 9px;
}

PatternTreeWidget QLabel[patternRole="patternName"] {
    color: @{text.primary};
    font-size: 12px;
    font-weight: 600;
}

PatternTreeWidget QLabel[patternRole="patternMeta"] {
    color: @{text.muted};
    font-size: 10px;
}

PatternTreeWidget QPushButton[patternAction="delete"] {
    background-color: @{state.error};
    color: @{text.on-accent};
    border: none;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 600;
    padding: 0;
}
PatternTreeWidget QPushButton[patternAction="delete"]:hover   { background-color: #c0282a; }
PatternTreeWidget QPushButton[patternAction="delete"]:pressed { background-color: @{state.error.deep}; }

PatternTreeWidget QPushButton[patternAction="edit"] {
    background-color: @{bg.window};
    color: @{text.primary};
    border: 1px solid @{border.default};
    border-radius: 4px;
    font-size: 11px;
    font-weight: 600;
    padding: 0;
}
PatternTreeWidget QPushButton[patternAction="edit"]:hover   { background-color: @{selection.bg}; color: @{accent.primary}; border-color: @{accent.primary}; }
PatternTreeWidget QPushButton[patternAction="edit"]:pressed { background-color: @{accent.primary}; color: @{text.on-accent}; }

/* ═══════════════════════════════════════════════════════════════════
   StatusLamp — Dark theme
   Read-only state indicator for operator dashboards.
   Severity communicated by left 4 px border + state label colour.
   ═══════════════════════════════════════════════════════════════════ */

StatusLamp {
    background-color: @{bg.surface};
    border-top:    1px solid @{border.default};
    border-right:  1px solid @{border.default};
    border-bottom: 1px solid @{border.default};
    border-left:   4px solid @{border.default};
    border-radius: 4px;
}
StatusLamp[status="ok"]      { border-left-color: @{state.success}; }
StatusLamp[status="warning"] { border-left-color: @{state.warning}; }
StatusLamp[status="error"]   { border-left-color: @{state.error}; }
StatusLamp[status="off"]     { border-left-color: @{border.default}; }

StatusLamp QLabel[lampPart="name"] {
    color: @{text.muted};
    font-size: 9px;
    font-weight: 700;
    background: transparent;
}
StatusLamp QLabel[lampPart="state"] {
    font-size: 13px;
    font-weight: 700;
    background: transparent;
}
StatusLamp[status="ok"]      QLabel[lampPart="state"] { color: @{state.success}; }
StatusLamp[status="warning"] QLabel[lampPart="state"] { color: @{state.warning}; }
StatusLamp[status="error"]   QLabel[lampPart="state"] { color: @{state.error}; }
StatusLamp[status="off"]     QLabel[lampPart="state"] { color: @{border.strong}; }

/* ═══════════════════════════════════════════════════════════════════
   TaskEventLogWidget — Dark theme
   Industrial operator event/alarm log.
   Severity is communicated by the left accent bar colour + level text.
   Row background stays neutral so selection highlight reads clearly.
   ═══════════════════════════════════════════════════════════════════ */

TaskEventLogWidget {
    background-color: @{bg.window};
    border: 1px solid @{border.default};
    border-radius: 4px;
    outline: none;
}
TaskEventLogWidget::item {
    padding: 0;
    margin: 0;
    border: none;
    border-bottom: 1px solid @{bg.elevated};
    background: transparent;
}
TaskEventLogWidget::item:selected { background-color: @{bg.elevated}; }
TaskEventLogWidget::item:hover:!selected { background-color: @{bg.surface}; }

/* Item wrapper — transparent; severity shown by bar + text only */
TaskEventItemWidget { background: transparent; }

/* ── Left severity bar ───────────────────────────────────────── */
TaskEventItemWidget QFrame[eventPart="bar"] { border-radius: 0px; }

TaskEventItemWidget[severity="info"]    QFrame[eventPart="bar"] { background-color: @{accent.primary}; }
TaskEventItemWidget[severity="warning"] QFrame[eventPart="bar"] { background-color: @{state.warning}; }
TaskEventItemWidget[severity="error"]   QFrame[eventPart="bar"] { background-color: @{state.error}; }
TaskEventItemWidget[severity="success"] QFrame[eventPart="bar"] { background-color: @{state.success}; }

/* ── Timestamp ───────────────────────────────────────────────── */
TaskEventItemWidget QLabel[eventPart="time"] {
    color: @{text.muted};
    font-family: "JetBrains Mono", Consolas, monospace;
    font-size: 10px;
}

/* ── Level badge ─────────────────────────────────────────────── */
TaskEventItemWidget[severity="info"]    QLabel[eventPart="level"] { color: @{accent.primary}; }
TaskEventItemWidget[severity="warning"] QLabel[eventPart="level"] { color: @{state.warning}; }
TaskEventItemWidget[severity="error"]   QLabel[eventPart="level"] { color: @{state.error}; }
TaskEventItemWidget[severity="success"] QLabel[eventPart="level"] { color: @{state.success}; }

TaskEventItemWidget QLabel[eventPart="level"] {
    font-family: "JetBrains Mono", Consolas, monospace;
    font-size: 10px;
    font-weight: 700;
}

/* ── Source tag ──────────────────────────────────────────────── */
TaskEventItemWidget QLabel[eventPart="source"] {
    color: @{border.strong};
    font-size: 10px;
    font-style: italic;
}

/* ── Message text ────────────────────────────────────────────── */
TaskEventItemWidget QLabel[eventPart="message"] { color: @{text.primary}; font-size: 11px; }

TaskEventItemWidget[severity="error"]   QLabel[eventPart="message"] { color: @{state.error.surface}; }
TaskEventItemWidget[severity="warning"] QLabel[eventPart="message"] { color: @{state.warning.surface}; }

/* ═══════════════════════════════════════════════════════════════════
   Qt Advanced Docking System — Dark theme
   ADS internal stylesheet disabled via CDockManager::setStyleSheet("").
   All ads-- rules are owned here using §5 tokens.
   ═══════════════════════════════════════════════════════════════════ */

/* ── Container / Splitter ────────────────────────────────────────── */

ads--CDockContainerWidget {
    background: @{bg.window};
}

ads--CDockContainerWidget > QSplitter {
    padding: 1 0 1 0;
}

ads--CDockSplitter::handle {
    background-color: @{border.default};
}

/* ── Dock area ───────────────────────────────────────────────────── */

ads--CDockAreaWidget {
    background: @{bg.window};
}

ads--CDockAreaTitleBar {
    background: @{bg.surface};
    border-bottom: 2px solid @{border.default};
    padding-bottom: 0px;
}

ads--CDockAreaWidget[focused="true"] ads--CDockAreaTitleBar {
    border-bottom: 2px solid @{accent.primary};
}

/* ── Dock widget content ─────────────────────────────────────────── */

ads--CDockWidget {
    background: @{bg.surface};
    border-color: @{border.default};
    border-style: solid;
    border-width: 1px 0 0 0;
}

QScrollArea#dockWidgetScrollArea {
    padding: 0px;
    border: none;
}

/* ── Tabs ────────────────────────────────────────────────────────── */

ads--CDockWidgetTab {
    background: @{bg.window};
    border-color: @{border.default};
    border-style: solid;
    border-width: 0 1px 0 0;
    padding: 0 4px;
    qproperty-iconSize: 16px 16px;
}

ads--CDockWidgetTab[activeTab="true"] {
    background: @{bg.surface};
}

ads--CDockWidgetTab QLabel {
    color: @{text.muted};
}

ads--CDockWidgetTab[activeTab="true"] QLabel {
    color: @{text.primary};
}

ads--CDockWidgetTab[focused="true"] {
    background: @{accent.primary};
    border-color: @{accent.primary};
}

ads--CDockWidgetTab[focused="true"] QLabel {
    color: @{text.on-accent};
}

/* ── Tab close button ────────────────────────────────────────────── */

#tabCloseButton {
    margin-top: 2px;
    background: none;
    border: none;
    padding: 0px -2px;
    qproperty-icon: url(:/ads/images/close-button.svg),
        url(:/ads/images/close-button-disabled.svg) disabled;
    qproperty-iconSize: 16px;
}
#tabCloseButton:hover   { background: @{overlay.tint.weak}; }
#tabCloseButton:pressed { background: @{overlay.tint.med}; }

ads--CDockWidgetTab[focused="true"] > #tabCloseButton {
    qproperty-icon: url(:/ads/images/close-button-focused.svg);
}
ads--CDockWidgetTab[focused="true"] > #tabCloseButton:hover   { background: @{overlay.tint.med}; }
ads--CDockWidgetTab[focused="true"] > #tabCloseButton:pressed { background: @{overlay.tint.strong}; }

/* ── Title bar buttons ───────────────────────────────────────────── */

ads--CTitleBarButton { padding: 0px 0px; }

#tabsMenuButton::menu-indicator { image: none; }

#dockAreaCloseButton {
    qproperty-icon: url(:/ads/images/close-button.svg),
        url(:/ads/images/close-button-disabled.svg) disabled;
    qproperty-iconSize: 16px;
}

#detachGroupButton {
    qproperty-icon: url(:/ads/images/detach-button.svg),
        url(:/ads/images/detach-button-disabled.svg) disabled;
    qproperty-iconSize: 16px;
}

/* ── Auto-hide tabs ──────────────────────────────────────────────── */

ads--CAutoHideTab {
    qproperty-iconSize: 16px 16px;
    background: none;
    border: none;
    padding-left: 2px;
    padding-right: 0px;
    text-align: center;
    min-height: 20px;
    padding-bottom: 2px;
    color: @{text.muted};
}
ads--CAutoHideTab:hover { color: @{accent.primary}; }

ads--CAutoHideTab[iconOnly="false"][sideBarLocation="0"],
ads--CAutoHideTab[iconOnly="false"][sideBarLocation="2"] { border-top:    6px solid rgba(58, 63, 72, 0.6); }
ads--CAutoHideTab[iconOnly="false"][sideBarLocation="1"],
ads--CAutoHideTab[iconOnly="false"][sideBarLocation="3"] { border-bottom: 6px solid rgba(58, 63, 72, 0.6); }

ads--CAutoHideTab:hover[iconOnly="false"][sideBarLocation="0"],
ads--CAutoHideTab:hover[iconOnly="false"][sideBarLocation="2"],
ads--CAutoHideTab[iconOnly="false"][sideBarLocation="0"][activeTab="true"],
ads--CAutoHideTab[iconOnly="false"][sideBarLocation="2"][activeTab="true"] { border-top:    6px solid @{accent.primary}; }

ads--CAutoHideTab:hover[iconOnly="false"][sideBarLocation="1"],
ads--CAutoHideTab:hover[iconOnly="false"][sideBarLocation="3"],
ads--CAutoHideTab[iconOnly="false"][sideBarLocation="1"][activeTab="true"],
ads--CAutoHideTab[iconOnly="false"][sideBarLocation="3"][activeTab="true"] { border-bottom: 6px solid @{accent.primary}; }

ads--CAutoHideTab[iconOnly="true"][sideBarLocation="0"] { border-top:    6px solid rgba(58, 63, 72, 0.6); }
ads--CAutoHideTab[iconOnly="true"][sideBarLocation="1"] { border-left:   6px solid rgba(58, 63, 72, 0.6); }
ads--CAutoHideTab[iconOnly="true"][sideBarLocation="2"] { border-right:  6px solid rgba(58, 63, 72, 0.6); }
ads--CAutoHideTab[iconOnly="true"][sideBarLocation="3"] { border-bottom: 6px solid rgba(58, 63, 72, 0.6); }

ads--CAutoHideTab:hover[iconOnly="true"][sideBarLocation="0"],
ads--CAutoHideTab[iconOnly="true"][sideBarLocation="0"][activeTab="true"] { border-top:    6px solid @{accent.primary}; }
ads--CAutoHideTab:hover[iconOnly="true"][sideBarLocation="1"],
ads--CAutoHideTab[iconOnly="true"][sideBarLocation="1"][activeTab="true"] { border-left:   6px solid @{accent.primary}; }
ads--CAutoHideTab:hover[iconOnly="true"][sideBarLocation="2"],
ads--CAutoHideTab[iconOnly="true"][sideBarLocation="2"][activeTab="true"] { border-right:  6px solid @{accent.primary}; }
ads--CAutoHideTab:hover[iconOnly="true"][sideBarLocation="3"],
ads--CAutoHideTab[iconOnly="true"][sideBarLocation="3"][activeTab="true"] { border-bottom: 6px solid @{accent.primary}; }

/* ── Auto-hide sidebar ───────────────────────────────────────────── */

ads--CAutoHideSideBar {
    background: @{bg.window};
    border: none;
    qproperty-spacing: 12;
}
#sideTabsContainerWidget { background: transparent; }

ads--CAutoHideSideBar[sideBarLocation="0"] { border-bottom: 1px solid @{border.default}; }
ads--CAutoHideSideBar[sideBarLocation="1"] { border-right:  1px solid @{border.default}; }
ads--CAutoHideSideBar[sideBarLocation="2"] { border-left:   1px solid @{border.default}; }
ads--CAutoHideSideBar[sideBarLocation="3"] { border-top:    1px solid @{border.default}; }

/* ── Auto-hide dock container ────────────────────────────────────── */

ads--CAutoHideDockContainer { background: @{bg.surface}; }

ads--CAutoHideDockContainer ads--CDockAreaTitleBar,
ads--CAutoHideDockContainer ads--CDockAreaWidget[focused="true"] ads--CDockAreaTitleBar {
    background: @{accent.primary};
    padding: 0px;
    border: none;
}

ads--CAutoHideDockContainer #autoHideTitleLabel {
    padding-left: 4px;
    color: @{text.on-accent};
}
#autoHideTitleLabel {
    padding-left: 4px;
    color: @{text.primary};
}

#dockAreaAutoHideButton {
    qproperty-icon: url(:/ads/images/vs-pin-button.svg),
        url(:/ads/images/vs-pin-button-disabled.svg) disabled;
    qproperty-iconSize: 16px;
}
ads--CAutoHideDockContainer #dockAreaAutoHideButton {
    qproperty-icon: url(:/ads/images/vs-pin-button-pinned-focused.svg);
    qproperty-iconSize: 16px;
}
ads--CAutoHideDockContainer #dockAreaMinimizeButton {
    qproperty-icon: url(:/ads/images/minimize-button-focused.svg);
    qproperty-iconSize: 16px;
}
ads--CAutoHideDockContainer #dockAreaCloseButton {
    qproperty-icon: url(:/ads/images/close-button-focused.svg);
}

ads--CAutoHideDockContainer ads--CTitleBarButton:hover   { background: @{overlay.tint.med}; }
ads--CAutoHideDockContainer ads--CTitleBarButton:pressed { background: @{overlay.tint.strong}; }

/* ── Resize handle ───────────────────────────────────────────────── */

ads--CResizeHandle { background: @{bg.window}; }

ads--CAutoHideDockContainer[sideBarLocation="0"] ads--CResizeHandle { border-top:    1px solid @{border.default}; }
ads--CAutoHideDockContainer[sideBarLocation="1"] ads--CResizeHandle { border-left:   1px solid @{border.default}; }
ads--CAutoHideDockContainer[sideBarLocation="2"] ads--CResizeHandle { border-right:  1px solid @{border.default}; }
ads--CAutoHideDockContainer[sideBarLocation="3"] ads--CResizeHandle { border-top:    1px solid @{border.default}; }
