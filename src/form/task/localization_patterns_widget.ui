     <property name="styleSheet">
      <string notr="true">QFrame#frame_toolbar {
    background-color: #2b3340;
    border-bottom: 1px solid #1a212c;
}
QFrame#frame_toolbar QToolButton {
    color: #e6ecf3;
    background-color: transparent;
    border: 1px solid transparent;
    padding: 4px 12px;
    border-radius: 3px;
    font: 600 10pt &quot;Segoe UI&quot;;
}
QFrame#frame_toolbar QToolButton:hover {
    background-color: #38465a;
    border: 1px solid #4a5b73;
}
QFrame#frame_toolbar QToolButton:pressed {
    background-color: #1d2632;
}
QFrame#frame_toolbar QToolButton#btn_run_match {
    background-color: #2c8b3f;
    border: 1px solid #246f33;
}
QFrame#frame_toolbar QToolButton#btn_run_match:hover {
    background-color: #34a049;
}
QFrame#frame_toolbar QToolButton#btn_run_match:disabled {
    background-color: #3a4452;
    color: #7a8492;
    border-color: #303a48;
}
QFrame#frame_toolbar QLabel {
    color: #c9d2dd;
    font: 10pt &quot;Segoe UI&quot;;
}
QFrame#frame_toolbar QFrame[role=&quot;separator&quot;] {
    background-color: #1a212c;
    max-width: 1px;
    min-width: 1px;
}</string>
